# Directus Configuration
DIRECTUS_PORT=8055
SECRET=your-secret-key

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# WebSocket Configuration
WEBSOCKETS_ENABLED=true

# URL Configuration
PUBLIC_URL=http://localhost:8055

# CORS Configuration:
# Development: "*" o "http://localhost:3000"
# Producción: especificar orígenes exactos, por ejemplo:
# "https://app.domain.com,https://admin.domain.com"
CORS_ENABLED=true
CORS_ORIGIN=*

# Cache config
CACHE_ENABLED=false

# Database config
DB_CLIENT=sqlite3
DB_FILENAME=/directus/data/directus.db

# Cookie Configuration
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=localhost

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=localhost

# Extensions Configuration
EXTENSIONS_PATH=./extensions
EXTENSIONS_AUTO_RELOAD=true

# Storage config
STORAGE_LOCATIONS=r2

STORAGE_R2_DRIVER=s3
STORAGE_R2_KEY=your-r2-key
STORAGE_R2_SECRET=your-r2-secret
STORAGE_R2_BUCKET=your-bucket-name
STORAGE_R2_REGION=auto
STORAGE_R2_ENDPOINT=https://your-r2-endpoint
STORAGE_R2_FORCE_PATH_STYLE=true

# Mail config
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASSWORD=your-smtp-password
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_NAME=Your App Name

# Content Security Policy
CONTENT_SECURITY_POLICY_DIRECTIVES__FRAME_SRC=http://localhost:3000,http://localhost:4321,http://localhost:5173,https://*.youtube.com,https://*.vimeo.com,https://*.wistia.net,https://*.loom.com
